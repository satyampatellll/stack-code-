{
  "name": "rgpv-ai-agent",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript AI agent for RGPV data collection, notes, previous year questions, and chatbot Q&A.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "scrape": "ts-node src/index.ts scrape",
    "chat": "ts-node src/index.ts chat",
    "search": "ts-node src/index.ts search"
  },
  "dependencies": {
    "axios": "^1.7.6",
    "better-sqlite3": "^12.10.0",
    "cheerio": "^1.0.0-rc.14",
    "dotenv": "^16.3.1",
    "openai": "^4.12.0"
  },
  "devDependencies": {
    "@types/cheerio": "^1.0.0",
    "@types/node": "^20.14.2",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.2"
  }
}
